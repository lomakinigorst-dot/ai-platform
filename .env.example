# База данных
POSTGRES_PASSWORD=secret
DATABASE_URL=postgresql+asyncpg://aiplatform:secret@localhost:5432/aiplatform

# Redis
REDIS_URL=redis://localhost:6379/0

# AI провайдеры (прямые API — не через агрегаторы)
DEEPSEEK_API_KEY=sk-...          # platform.deepseek.com — диалоги
ANTHROPIC_API_KEY=sk-ant-...     # console.anthropic.com — анализ, ДНК, тексты
OPENAI_API_KEY=sk-...            # platform.openai.com — только эмбеддинги
FIRECRAWL_API_KEY=fc-...         # firecrawl.dev — сканирование сайтов

# Безопасность
SECRET_KEY=замени-на-случайную-строку-минимум-32-символа
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# S3 (Yandex Object Storage)
S3_ENDPOINT_URL=https://storage.yandexcloud.net
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET=ai-platform-files
S3_REGION=ru-central1

# Telegram (бот для уведомлений агенту)
TELEGRAM_BOT_TOKEN=

# Домен (для виджета и демо-ссылок)
BASE_DOMAIN=localhost

# Окружение
ENVIRONMENT=development
DEBUG=true
